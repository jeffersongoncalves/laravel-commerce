includes:
    - vendor/larastan/larastan/extension.neon

parameters:
    paths:
        - packages/suite/src
        - packages/core/src
        - packages/core/tests/Fixtures
        - packages/currency/src
        - packages/store/src
        - packages/sales-channel/src
        - packages/region/src
        - packages/stock-location/src
        - packages/api-key/src
        - packages/user/src
        - packages/auth/src
        - packages/product/src
    level: 5
    ignoreErrors: []
