{
    "name": "jeffersongoncalves/laravel-commerce-monorepo",
    "description": "Development monorepo (source-of-truth, not published) for the Laravel Commerce domain ecosystem. Component packages split read-only into jeffersongoncalves/laravel-commerce-* and the umbrella into jeffersongoncalves/laravel-commerce-suite (package jeffersongoncalves/laravel-commerce).",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Jefferson Gonçalves",
            "email": "gerson.simao.92@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/events": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "spatie/laravel-package-tools": "^1.15"
    },
    "require-dev": {
        "larastan/larastan": "^2.9|^3.0",
        "laravel/pint": "^1.0",
        "nunomaduro/collision": "^8.0",
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^3.0|^4.0",
        "symplify/monorepo-builder": "^11.2"
    },
    "autoload-dev": {
        "psr-4": {
            "JeffersonGoncalves\\Commerce\\Suite\\": "packages/suite/src",
            "JeffersonGoncalves\\Commerce\\Suite\\Tests\\": "packages/suite/tests",
            "JeffersonGoncalves\\Commerce\\Core\\": "packages/core/src",
            "JeffersonGoncalves\\Commerce\\Core\\Tests\\": "packages/core/tests",
            "JeffersonGoncalves\\Commerce\\Core\\Database\\Factories\\": "packages/core/database/factories",
            "JeffersonGoncalves\\Commerce\\Currency\\": "packages/currency/src",
            "JeffersonGoncalves\\Commerce\\Currency\\Tests\\": "packages/currency/tests",
            "JeffersonGoncalves\\Commerce\\Currency\\Database\\Factories\\": "packages/currency/database/factories",
            "JeffersonGoncalves\\Commerce\\Currency\\Database\\Seeders\\": "packages/currency/database/seeders",
            "JeffersonGoncalves\\Commerce\\Store\\": "packages/store/src",
            "JeffersonGoncalves\\Commerce\\Store\\Tests\\": "packages/store/tests",
            "JeffersonGoncalves\\Commerce\\Store\\Database\\Factories\\": "packages/store/database/factories",
            "JeffersonGoncalves\\Commerce\\SalesChannel\\": "packages/sales-channel/src",
            "JeffersonGoncalves\\Commerce\\SalesChannel\\Tests\\": "packages/sales-channel/tests",
            "JeffersonGoncalves\\Commerce\\SalesChannel\\Database\\Factories\\": "packages/sales-channel/database/factories",
            "JeffersonGoncalves\\Commerce\\Region\\": "packages/region/src",
            "JeffersonGoncalves\\Commerce\\Region\\Tests\\": "packages/region/tests",
            "JeffersonGoncalves\\Commerce\\Region\\Database\\Factories\\": "packages/region/database/factories",
            "JeffersonGoncalves\\Commerce\\StockLocation\\": "packages/stock-location/src",
            "JeffersonGoncalves\\Commerce\\StockLocation\\Tests\\": "packages/stock-location/tests",
            "JeffersonGoncalves\\Commerce\\StockLocation\\Database\\Factories\\": "packages/stock-location/database/factories",
            "JeffersonGoncalves\\Commerce\\ApiKey\\": "packages/api-key/src",
            "JeffersonGoncalves\\Commerce\\ApiKey\\Tests\\": "packages/api-key/tests",
            "JeffersonGoncalves\\Commerce\\ApiKey\\Database\\Factories\\": "packages/api-key/database/factories",
            "JeffersonGoncalves\\Commerce\\User\\": "packages/user/src",
            "JeffersonGoncalves\\Commerce\\User\\Tests\\": "packages/user/tests",
            "JeffersonGoncalves\\Commerce\\User\\Database\\Factories\\": "packages/user/database/factories",
            "JeffersonGoncalves\\Commerce\\Auth\\": "packages/auth/src",
            "JeffersonGoncalves\\Commerce\\Auth\\Tests\\": "packages/auth/tests",
            "JeffersonGoncalves\\Commerce\\Auth\\Database\\Factories\\": "packages/auth/database/factories",
            "JeffersonGoncalves\\Commerce\\Product\\": "packages/product/src",
            "JeffersonGoncalves\\Commerce\\Product\\Tests\\": "packages/product/tests",
            "JeffersonGoncalves\\Commerce\\Product\\Database\\Factories\\": "packages/product/database/factories",
            "JeffersonGoncalves\\Commerce\\Pricing\\": "packages/pricing/src",
            "JeffersonGoncalves\\Commerce\\Pricing\\Tests\\": "packages/pricing/tests",
            "JeffersonGoncalves\\Commerce\\Pricing\\Database\\Factories\\": "packages/pricing/database/factories",
            "JeffersonGoncalves\\Commerce\\Inventory\\": "packages/inventory/src",
            "JeffersonGoncalves\\Commerce\\Inventory\\Tests\\": "packages/inventory/tests",
            "JeffersonGoncalves\\Commerce\\Inventory\\Database\\Factories\\": "packages/inventory/database/factories",
            "JeffersonGoncalves\\Commerce\\Customer\\": "packages/customer/src",
            "JeffersonGoncalves\\Commerce\\Customer\\Tests\\": "packages/customer/tests",
            "JeffersonGoncalves\\Commerce\\Customer\\Database\\Factories\\": "packages/customer/database/factories",
            "JeffersonGoncalves\\Commerce\\Tax\\": "packages/tax/src",
            "JeffersonGoncalves\\Commerce\\Tax\\Tests\\": "packages/tax/tests",
            "JeffersonGoncalves\\Commerce\\Tax\\Database\\Factories\\": "packages/tax/database/factories",
            "JeffersonGoncalves\\Commerce\\Cart\\": "packages/cart/src",
            "JeffersonGoncalves\\Commerce\\Cart\\Tests\\": "packages/cart/tests",
            "JeffersonGoncalves\\Commerce\\Cart\\Database\\Factories\\": "packages/cart/database/factories",
            "JeffersonGoncalves\\Commerce\\Order\\": "packages/order/src",
            "JeffersonGoncalves\\Commerce\\Order\\Tests\\": "packages/order/tests",
            "JeffersonGoncalves\\Commerce\\Order\\Database\\Factories\\": "packages/order/database/factories",
            "JeffersonGoncalves\\Commerce\\Payment\\": "packages/payment/src",
            "JeffersonGoncalves\\Commerce\\Payment\\Tests\\": "packages/payment/tests",
            "JeffersonGoncalves\\Commerce\\Payment\\Database\\Factories\\": "packages/payment/database/factories",
            "JeffersonGoncalves\\Commerce\\Fulfillment\\": "packages/fulfillment/src",
            "JeffersonGoncalves\\Commerce\\Fulfillment\\Tests\\": "packages/fulfillment/tests",
            "JeffersonGoncalves\\Commerce\\Fulfillment\\Database\\Factories\\": "packages/fulfillment/database/factories",
            "JeffersonGoncalves\\Commerce\\Promotion\\": "packages/promotion/src",
            "JeffersonGoncalves\\Commerce\\Promotion\\Tests\\": "packages/promotion/tests",
            "JeffersonGoncalves\\Commerce\\Promotion\\Database\\Factories\\": "packages/promotion/database/factories",
            "JeffersonGoncalves\\Commerce\\Loyalty\\": "packages/loyalty/src",
            "JeffersonGoncalves\\Commerce\\Loyalty\\Tests\\": "packages/loyalty/tests",
            "JeffersonGoncalves\\Commerce\\Loyalty\\Database\\Factories\\": "packages/loyalty/database/factories",
            "JeffersonGoncalves\\Commerce\\StoreCredit\\": "packages/store-credit/src",
            "JeffersonGoncalves\\Commerce\\StoreCredit\\Tests\\": "packages/store-credit/tests",
            "JeffersonGoncalves\\Commerce\\StoreCredit\\Database\\Factories\\": "packages/store-credit/database/factories",
            "JeffersonGoncalves\\Commerce\\Translation\\": "packages/translation/src",
            "JeffersonGoncalves\\Commerce\\Translation\\Tests\\": "packages/translation/tests",
            "JeffersonGoncalves\\Commerce\\Translation\\Database\\Factories\\": "packages/translation/database/factories",
            "JeffersonGoncalves\\Commerce\\Checkout\\": "packages/checkout/src",
            "JeffersonGoncalves\\Commerce\\Checkout\\Tests\\": "packages/checkout/tests",
            "JeffersonGoncalves\\Commerce\\Storefront\\": "packages/storefront/src",
            "JeffersonGoncalves\\Commerce\\Storefront\\Tests\\": "packages/storefront/tests"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint",
        "analyse": "vendor/bin/phpstan analyse"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
